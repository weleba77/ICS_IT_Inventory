rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: inventory
    // Document ID: auto-generated
    // Fields:
    //   - deviceName: string (required, 1-100 chars)
    //   - serialNumber: string (required, 1-100 chars)
    //   - type: string (required, 1-50 chars)
    //   - location: string (required, 1-100 chars)
    //   - notes: string (optional, 0-500 chars)
    //   - status: string (required, enum: ACTIVE, INACTIVE)
    //   - remarks: string (optional, 0-500 chars)
    //   - checkedDate: string (optional, format: YYYY-MM-DD or similar)
    //   - responsiblePerson: string (required, 1-100 chars)
    //   - createdAt: timestamp (required)
    //   - updatedAt: timestamp (required)
    //   - createdBy: string (required, UID)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "ephremweleba94@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidInventoryItem(data) {
      return hasRequiredFields(['deviceName', 'serialNumber', 'type', 'location', 'status', 'responsiblePerson', 'createdAt', 'updatedAt', 'createdBy']) &&
             data.deviceName is string && data.deviceName.size() > 0 && data.deviceName.size() <= 100 &&
             data.serialNumber is string && data.serialNumber.size() > 0 && data.serialNumber.size() <= 100 &&
             data.type is string && data.type.size() > 0 && data.type.size() <= 50 &&
             data.location is string && data.location.size() > 0 && data.location.size() <= 100 &&
             data.responsiblePerson is string && data.responsiblePerson.size() > 0 && data.responsiblePerson.size() <= 100 &&
             data.status in ['ACTIVE', 'INACTIVE'] &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp &&
             data.createdBy == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }

    match /inventory/{itemId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidInventoryItem(request.resource.data);
      allow update: if isAdmin() && isValidInventoryItem(request.resource.data);
      allow delete: if isAdmin();
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
